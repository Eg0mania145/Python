def show_status(inventory, player_health, money, name):
    print("\n--- STATUS ---")
    print(f"Name: {name}")
    print(f"Health: {player_health}")
    print(f"Money: {money}")
    inv = ", ".join(f"{k}×{v}" for k,v in inventory.items() if v > 0)
    print(f"Inventory: {inv if inv else 'empty'}")
    print("----------------\n")

