def clear():
    os.system("cls" if os.name == "nt" else "clear")

def pause(t=1.3):
    time.sleep(t)

def ask_int(prompt, valid=None):
    while True:
        val = input(prompt).strip()
        if not val.isdigit():
            print("Skriv en siffra.")
            continue
        val = int(val)
        if valid and val not in valid:
            print(f"Ogiltigt val. Välj: {', '.join(map(str, valid))}")
            continue
        return val

def ask_nonempty(prompt):
    while True:
        val = input(prompt).strip()
        if val:
            return val
        print("Skriv något, det kan inte vara tomt.")

