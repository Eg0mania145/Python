def choose_item(inventory):
    print("The Old man offers you one item for free :")
    print("1)Gun \n2)Frying pan \n3)Baby knife \n4)Sword \n5)\"Healing\" powder")
    val = ask_int(": ", valid={1,2,3,4,5})
    items = {1:"gun", 2:"frying pan", 3:"baby knife", 4:"sword", 5:"healing powder"}
    item = items[val]
    inventory[item] = inventory.get(item, 0) + 1
    if item == "gun":
        inventory["ammo"] = inventory.get("ammo", 0) + 0
    print(f"You have chosen {item}")
    pause()

def store(inventory, money):
    clear()
    print("You continue to walk through the town, on your way, you spot a store selling goods for travelers.\n *you think 'perfect just what i need!'*")
    print("You enter the store, and the shopkeeper greets you...")
    pause()
    print("Welcome to my store, what can i do for you?")
    val = ask_int("1)Show me your goods \n2)Nothing, just looking around\n: ", valid={1,2})
    if val == 2:
        print("You decide to just look around, the shopkeeper looks at you with a disappointed look")
        print("Shopkeeper: 'If you need anything, just let me know'")
        pause()
        return money
    print("The shopkeeper shows you his goods, he has a variety of items that can help you on your journey")
    print("1)\"Healing\" powder - 50 coins \n2)Sword - 100 coins \n3)gun - 100 \n4)Ammo for gun - 25 coins \n5)Nothing")
    val = ask_int("Which item do you want to buy? ", valid={1,2,3,4,5})
    items = {1:"healing powder", 2:"sword", 3:"gun", 4:"ammo", 5:"nothing"}
    costs = {"healing powder":50, "sword":100, "gun":100, "ammo":25, "nothing":0}
    item = items[val]
    cost = costs[item]
    if item == "nothing":
        print("you decide not to buy anything, the shopkeeper yells at you for wasting his time")
        money -= 20
        print(f"you now have {money} generic currency")
        pause()
        return money
    if money < cost:
        print("You don't have enough money.")
        pause()
        return money
    money -= cost
    if item == "ammo":
        inventory["ammo"] = inventory.get("ammo", 0) + 3
        print("You have bought ammo for your gun")
    else:
        inventory[item] = inventory.get(item, 0) + 1
        print(f"You have bought a {item}")
    print(f"you now have {money} generic currency")
    time.sleep(2)
    return money

